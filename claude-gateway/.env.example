# Mr. Crab — Environment Configuration
# Copy this to .env and fill in your values

# ============================================================
# AI PROVIDER — pick one, set AI_API_KEY + AI_BASE_URL + AI_MODEL
# ============================================================
#
# BEST FREE MODELS (ranked by capability):
#   1. llama3.1:70b  — GPT-4 level, needs 40GB RAM or GPU (Ollama)
#   2. llama3.1:8b   — Great quality, runs on 8GB RAM (Ollama) ← DEFAULT
#   3. llama3.2-vision:11b — Supports images, needs 16GB (Ollama)
#   4. deepseek-r1   — Best at reasoning/math (Ollama)
#   5. qwen3:8b      — Strong multilingual (Ollama)
#
# Run scripts/install-ollama.sh on your VM to auto-install the best model!

# --- OPTION 1: Ollama (100% FREE, runs on your VM) --- ← RECOMMENDED
# Install: bash scripts/install-ollama.sh
AI_API_KEY=ollama
AI_BASE_URL=http://localhost:11434/v1
AI_MODEL=llama3.1:8b
# Upgrade to bigger model if your VM has more RAM/GPU:
#   AI_MODEL=llama3.1:70b              (best, needs 40GB+)
#   AI_MODEL=llama3.2-vision:11b       (supports images, needs 16GB)
#   AI_MODEL=deepseek-r1:14b           (best reasoning, needs 10GB)
#   AI_MODEL=qwen3:8b                  (great multilingual)

# --- OPTION 2: NVIDIA NIM (FREE cloud API — no GPU needed) ---
# Sign up free at https://build.nvidia.com → click any model → "Get API Key"
#AI_API_KEY=nvapi-YOUR_KEY_HERE
#AI_BASE_URL=https://integrate.api.nvidia.com/v1
#AI_MODEL=meta/llama-3.1-405b-instruct   # most powerful free model on NVIDIA

# --- OPTION 2: Kimi (Moonshot AI) ---
# Sign up at https://platform.moonshot.cn
#AI_API_KEY=sk-YOUR_KIMI_KEY
#AI_BASE_URL=https://api.moonshot.cn/v1
#AI_MODEL=moonshot-v1-8k

# --- OPTION 3: Groq (free tier, very fast) ---
# Sign up at https://console.groq.com
#AI_API_KEY=gsk_YOUR_GROQ_KEY
#AI_BASE_URL=https://api.groq.com/openai/v1
#AI_MODEL=llama-3.1-70b-versatile

# --- OPTION 4: Ollama (fully local, no API key needed) ---
# Install: curl -fsSL https://ollama.com/install.sh | sh
# Then: ollama pull llama3.1
#AI_API_KEY=ollama
#AI_BASE_URL=http://localhost:11434/v1
#AI_MODEL=llama3.1

# ============================================================
# PLATFORMS — enable at least one
# ============================================================

# Telegram: get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Discord: https://discord.com/developers/applications
# Enable MESSAGE_CONTENT intent in the Dev Portal
DISCORD_BOT_TOKEN=

# WhatsApp: QR scan required on first run
# Requires: sudo apt install golang-go
WHATSAPP_SESSION_FILE=/opt/mrcrab/data/whatsapp.db

# iMessage — requires a Mac running BlueBubbles (https://bluebubbles.app)
BLUEBUBBLES_URL=http://YOUR_MAC_IP:1234
BLUEBUBBLES_PASSWORD=

# Slack (Socket Mode): https://api.slack.com/apps
# Bot scopes: app_mentions:read, im:history, im:write, chat:write, files:read
# Enable Socket Mode + Events: message.im, app_mention
SLACK_BOT_TOKEN=xoxb-
SLACK_APP_TOKEN=xapp-

# Webhook HTTP server (for automation/cron triggers)
WEBHOOK_ENABLED=false
WEBHOOK_PORT=8787
WEBHOOK_TOKEN=change_this_to_a_secret

# IDE WebSocket server (Cursor, VS Code, JetBrains, etc.)
# Connect from your editor at ws://127.0.0.1:8788/ide
IDE_ENABLED=false
IDE_PORT=8788
IDE_TOKEN=change_this_to_a_secret

# ============================================================
# OPTIONAL
# ============================================================

# Voice TTS replies on Telegram (https://elevenlabs.io)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Restrict to specific user IDs (comma-separated). Empty = allow all.
ALLOWED_USER_IDS=

# Tool safety limits
MAX_TOOL_ITERATIONS=10
DATA_DIR=/opt/mrcrab/data
WORKSPACE_DIR=/opt/mrcrab/data/workspace

# Session settings
SESSION_TTL_DAYS=30
MAX_HISTORY_TOKENS=100000
MAX_MESSAGE_LENGTH=4000
